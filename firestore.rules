rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function getUserData(userId) { return get(/databases/$(database)/documents/users/$(userId)).data; }
    function isAdmin() { return isSignedIn() && (getUserData(request.auth.uid).role == "admin" || request.auth.token.email == "alqaidpro@gmail.com"); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // Validation Blueprints
    function isValidOrder(data) {
      return data.keys().hasAll(['name', 'amount', 'userId', 'status']) &&
             data.userId is string &&
             data.status in ['pending', 'processing', 'active', 'completed', 'rejected'];
    }

    function isValidSupportTicket(data) {
      return data.keys().hasAll(['userId', 'subject', 'message', 'status']) &&
             data.userId is string &&
             data.subject is string && data.subject.size() > 0 &&
             data.message is string && data.message.size() > 0 &&
             data.status in ['open', 'replied', 'closed'];
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['userId', 'title', 'msg']) &&
             data.userId is string &&
             data.title is string &&
             data.msg is string;
    }

    function isValidDepositRequest(data) {
      return data.keys().hasAll(['userId', 'amount', 'status']) &&
             data.userId is string &&
             data.amount is number &&
             data.status in ['pending', 'approved', 'rejected'];
    }

    // Collection Rules
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isOwner(userId); 
      allow update: if isAdmin() || 
                    (isOwner(userId) && 
                     incoming().diff(existing()).affectedKeys().hasOnly(['name', 'email', 'country', 'province', 'city', 'address', 'phone', 'balance', 'rewardPoints', 'referralCode', 'updatedAt']) &&
                     (
                       !incoming().diff(existing()).affectedKeys().contains('balance') || // Balance not changed
                       incoming().balance <= existing().balance || // Balance decreased
                       (incoming().balance - existing().balance == existing().rewardPoints - incoming().rewardPoints) // Balance increased via points conversion
                     )) ||
                    (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['rewardPoints']));
    }

    match /system/connection_test {
      allow read: if true;
    }

    match /orders/{orderId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin() || resource.data.status == "completed");
      allow list: if isAdmin() || (isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.status == "completed"));
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidOrder(incoming());
      allow update: if isAdmin();
    }

    match /deposit_requests/{requestId} {
      allow get: if isOwner(existing().userId) || isAdmin();
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && isValidDepositRequest(incoming()) && incoming().status == "pending";
      allow update: if isAdmin();
    }

    match /notifications/{notifId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /support_tickets/{ticketId} {
      allow get: if isOwner(existing().userId) || isAdmin();
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && isValidSupportTicket(incoming());
      allow update: if isAdmin();
    }

    match /configs/{configId} {
      allow read: if true;
      allow write: if isAdmin() || (isSignedIn() && configId == "stats");
    }
  }
}
